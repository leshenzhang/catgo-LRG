{
  "name": "@catgo/ferrox-wasm",
  "version": "0.0.4",
  "type": "module",
  "description": "WASM bindings for ferrox (high-performance crystallography). Wrapper around pkg/ generated by wasm-pack.",
  "license": "MIT",
  "main": "./pkg/ferrox.js",
  "module": "./pkg/ferrox.js",
  "types": "./pkg/ferrox.d.ts",
  "exports": {
    ".": {
      "types": "./pkg/ferrox.d.ts",
      "import": "./pkg/ferrox.js",
      "default": "./pkg/ferrox.js"
    },
    "./ferrox_bg.wasm": "./pkg/ferrox_bg.wasm",
    "./pkg/*": "./pkg/*"
  },
  "files": [
    "pkg"
  ],
  "scripts": {
    "build": "cd ../rust && wasm-pack build --target web --out-dir ../rust-wasm/pkg --features wasm"
  }
}
