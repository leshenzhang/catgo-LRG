{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "CatGo",
  "version": "1.4.1",
  "identifier": "com.catgo.app",
  "build": {
    "frontendDist": "../build-desktop",
    "devUrl": "http://localhost:3100",
    "beforeDevCommand": "pnpm desktop:serve",
    "beforeBuildCommand": "pnpm desktop:build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "CatGo - AI Workbench for Computational Materials",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Hello-QM/catgo-LRG/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI5QUM5OTQwNjdENjIyMjYKUldRbUl0Wm5RSm1zS2N5L2xiM3VrU2VteUtZSzNySkp6VlZmNmk0UHFoVmNuR2NqZ0ZKNzQzMnoK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/catgo-server",
      "binaries/catgo-agent"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Education",
    "shortDescription": "Interactive visualizations for materials science",
    "longDescription": "CatGo provides interactive visualizations for materials science including periodic tables, 3D crystal structures, molecular dynamics trajectories, and more.",
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installerHooks": "./windows/installer-hooks.nsh"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "files": {
          "/usr/bin/catgo-cli": "../deploy/cli/catgo-cli"
        }
      },
      "rpm": {
        "files": {
          "/usr/bin/catgo-cli": "../deploy/cli/catgo-cli"
        }
      }
    },
    "iOS": {
      "minimumSystemVersion": "17.0",
      "infoPlist": "Info.ios.plist"
    },
    "resources": {
      "icons/document.icns": "./"
    },
    "fileAssociations": [
      {
        "ext": [
          "cif"
        ],
        "name": "CIF Structure",
        "description": "Crystallographic Information File",
        "role": "Viewer",
        "rank": "Owner"
      },
      {
        "ext": [
          "poscar",
          "vasp",
          "contcar"
        ],
        "name": "VASP Structure",
        "description": "VASP POSCAR/CONTCAR file",
        "role": "Viewer",
        "rank": "Owner"
      },
      {
        "ext": [
          "xyz",
          "extxyz"
        ],
        "name": "XYZ Structure",
        "description": "XYZ molecular structure file",
        "role": "Viewer",
        "rank": "Owner"
      },
      {
        "ext": [
          "traj"
        ],
        "name": "ASE Trajectory",
        "description": "ASE trajectory file",
        "role": "Viewer",
        "rank": "Owner"
      },
      {
        "ext": [
          "json"
        ],
        "name": "JSON Structure",
        "description": "JSON structure data",
        "role": "Viewer",
        "rank": "Owner"
      }
    ]
  }
}
