# Build artifacts + Tauri-generated bindings — all regenerated by `cargo build`
# / `tauri ios`. Only the hand-authored source + permissions/default.toml are
# committed. Without this, `tauri ios dev`'s file watcher sees the regenerated
# permissions/.build files as source changes and rebuild-loops (reinstalling the
# app over and over). Mirrors tauri-plugin-ios-speech/.gitignore.
/.tauri/
/Cargo.lock
/ios/.build/
/ios/Package.resolved
/permissions/autogenerated/
/permissions/schemas/
