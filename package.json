    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-math": "3.0.1",
    "sharp": "^0.34.5",
    "svelte-check": "^4.3.3",
