  "keywords": [
    "svelte",
    "periodic table",
    "chemistry",
    "data viz",
    "plotting",
    "component"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./element/data": {
      "types": "./dist/element/data.d.ts",
      "default": "./dist/element/data.js"
    },
    "./app.css": {
      "types": "./dist/app.css.d.ts",
      "default": "./dist/app.css"
    },
    "./bands": {
      "types": "./dist/bands/index.d.ts",
      "default": "./dist/bands/index.js"
    },
    "./composition": {
      "types": "./dist/composition/index.d.ts",
      "default": "./dist/composition/index.js"
    },
    "./cube": {
      "types": "./dist/cube/index.d.ts",
      "svelte": "./dist/cube/index.js",
      "default": "./dist/cube/index.js"
    },
    "./colors": {
      "types": "./dist/colors/index.d.ts",
      "default": "./dist/colors/index.js"
    },
    "./element": {
      "types": "./dist/element/index.d.ts",
      "default": "./dist/element/index.js"
    },
    "./io": {
      "types": "./dist/io.d.ts",
      "default": "./dist/io.js"
    },
    "./labels": {
      "types": "./dist/labels.d.ts",
      "default": "./dist/labels.js"
    },
    "./math": {
      "types": "./dist/math.d.ts",
      "default": "./dist/math.js"
    },
    "./periodic-table": {
      "types": "./dist/periodic-table.d.ts",
      "default": "./dist/periodic-table.js"
    },
    "./phase-diagram": {
      "types": "./dist/phase-diagram.d.ts",
      "default": "./dist/phase-diagram.js"
    },
    "./plot": {
      "types": "./dist/plot/index.d.ts",
      "default": "./dist/plot/index.js"
    },
    "./structure": {
      "types": "./dist/structure/index.d.ts",
      "default": "./dist/structure/index.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "default": "./dist/theme/index.js"
    },
    "./theme/themes": {
      "types": "./dist/theme/themes.d.ts",
      "default": "./dist/theme/themes.js"
    },
    "./trajectory": {
      "types": "./dist/trajectory/index.d.ts",
      "default": "./dist/trajectory/index.js"
    },
    "./rdf": {
      "types": "./dist/rdf/index.d.ts",
      "default": "./dist/rdf/index.js"
    },
    "./xrd": {
      "types": "./dist/xrd/index.d.ts",
      "default": "./dist/xrd/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "pnpm": {
    "overrides": {
      "@tauri-apps/api": "2.9.1"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "node-pty",
      "sharp"
    ],
    "patchedDependencies": {
      "three@0.181.2": "patches/three@0.181.2.patch",
      "@openai/codex-sdk@0.132.0-alpha.1": "patches/@openai__codex-sdk@0.132.0-alpha.1.patch"
    }
  },
  "scripts": {
    "prepare": "svelte-kit sync || true",
    "build:doc-chunks": "node scripts/build-doc-chunks.js",
    "build:agent": "node scripts/build-agent-sidecar.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "desktop:dev": "node scripts/predev.mjs && vite --config vite.desktop.config.ts",
    "build:wasm": "node scripts/build-wasm.mjs",
    "desktop:build": "pnpm build:wasm && vite build --config vite.desktop.config.ts",
    "deploy:build": "pnpm build:wasm && VITE_STATIC_ONLY=true vite build --config vite.desktop.config.ts",
    "build:connect": "pnpm build:wasm && vite build --config vite.desktop.config.ts",
    "setup": "node scripts/setup.mjs",
    "setup:check": "node scripts/setup.mjs --check",
    "agent:dev": "node scripts/agent-dev.mjs",
    "desktop:serve": "concurrently -k -n fe,be,ag -c blue,green,magenta \"pnpm desktop:dev\" \"python server/main.py\" \"pnpm agent:dev\"",
    "tauri": "node scripts/tauri-dev.mjs",
    "tauri:dev": "pnpm desktop:build && node scripts/tauri-dev.mjs dev",
    "tauri:build": "pnpm build:agent && pnpm desktop:build && node scripts/patch-linuxdeploy-sidecars.mjs && tauri build",
    "tauri:build:windows": "pnpm build:agent win && pnpm desktop:build && tauri build --target x86_64-pc-windows-msvc",
    "tauri:build:mac": "pnpm build:agent mac-arm && pnpm desktop:build && tauri build --target universal-apple-darwin",
    "tauri:build:mac-arm": "pnpm build:agent mac-arm && pnpm desktop:build && tauri build --target aarch64-apple-darwin",
    "tauri:build:linux": "pnpm build:agent linux && pnpm desktop:build && node scripts/patch-linuxdeploy-sidecars.mjs && tauri build --target x86_64-unknown-linux-gnu",
    "tauri:icons": "node scripts/generate-icons.js",
    "backend:build": "bash scripts/build-backend.sh",
    "backend:build:windows": "bash scripts/build-backend.sh x86_64-pc-windows-msvc",
    "backend:build:mac-arm": "bash scripts/build-backend.sh aarch64-apple-darwin",
    "backend:build:linux": "bash scripts/build-backend.sh x86_64-unknown-linux-gnu",
    "bundle": "pnpm backend:build && pnpm tauri:build",
    "bundle:windows": "pnpm backend:build:windows && pnpm tauri:build:windows",
    "bundle:mac-arm": "pnpm backend:build:mac-arm && pnpm tauri:build:mac-arm",
    "vitest": "vitest",
    "test": "vitest run"
  }
}
