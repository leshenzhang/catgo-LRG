# Dependencies
node_modules/

# Local research / reference notes — not part of the published source tree
.acoord_research/

# SvelteKit / Vite build output
.svelte-kit/
build/
build-desktop/
dist/

# VitePress docs build
docs/.vitepress/dist/
docs/.vitepress/cache/

# Tauri
src-tauri/target/
src-tauri/gen/

# wasm-pack output (generated by `pnpm build` in extensions/rust-wasm)
extensions/rust-wasm/pkg/

# VSCode extension bundled binaries + packaged vsix
extensions/vscode/bin/
*.vsix

# Nested Cargo crates outside src-tauri
crates/*/target/
tools/*/target/
extensions/**/target/

# Python cache + virtualenv
__pycache__/
*.pyc

# Generated chat doc chunks (built by scripts/build-doc-chunks.js)
src/lib/chat/docs-chunks.json

# Test artefacts
coverage/
test-results*/
playwright-report/

# Runtime data
server/catgo/data/*.db
server/data/*.db
server/debug_output/
exports/
*.log

# HPC bundle staging
deploy/hpc/bundle/frontend/
deploy/hpc/bundle/server/
deploy/hpc/bundle/wheels/

# Secrets
.env
.gh/hosts.yml
.gh/config.yml

# Editor / OS metadata
.DS_Store
**/.DS_Store

# Local-only Claude Code settings
.claude/settings.local.json
.claude/settings.json
.claude/mcp.json
.claude/scheduled_tasks.lock

# Misc backup files
*.bak

# Container images
*.sif
*.tar
*.tar.gz

# Git worktrees
.worktrees/
.claude/worktrees/

# Vendored PORMAKE runtime topology caches (regenerated from .cgd on first use)
server/catgo/vendor/pormake/database/**/*.pickle

# Local dev / debugging artifacts
.playwright-mcp/
.claude/logs/
repro-*.jpeg
repro-*.png
